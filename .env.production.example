# Copy to .env on the VPS — `docker compose` reads this file automatically.
#   cp .env.production.example .env && nano .env
# Never commit the real .env (it is gitignored).

# The domain Caddy serves and obtains TLS certificates for.
# Must already point at this VPS's IP (A record) before the first deploy.
# Use SITE_DOMAIN=:80 to run without TLS (no domain yet / local testing).
SITE_DOMAIN=truoffers.co.uk
SITE_URL=https://truoffers.co.uk

# REQUIRED. Generate with: openssl rand -hex 32
# The API refuses to boot in production with a default/dev secret.
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Stripe (blank = billing and ad-wallet top-ups run in mock mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Social login (blank = the Google/Apple buttons show "not configured")
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=

# Google review sync (blank = seeded ratings are kept)
GOOGLE_PLACES_API_KEY=

# AI offer writer (blank = falls back to template copy)
ANTHROPIC_API_KEY=
