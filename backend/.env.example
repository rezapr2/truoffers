# Copy to .env and adjust
PORT=4000
MONGODB_URI=mongodb://localhost:27017/truoffers
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000

# Stripe (leave blank in dev — billing runs in mock mode)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Social login (leave blank to disable the providers)
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
