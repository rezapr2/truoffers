# Build-time config — lives on the BUILD machine (your Mac / CI), not the VPS.
# Copy to .env.build:  cp .env.build.example .env.build
#
# Contains no production secrets. These are the public NEXT_PUBLIC_* values that
# get compiled into the browser bundle, so they must match the live site.

# The public URL the browser will call. Baked into the frontend image.
# Rebuild + repush after changing this — a restart alone will not pick it up.
SITE_URL=https://truoffers.co.uk

# Where images are published. Must be lowercase (registries reject uppercase).
REGISTRY=ghcr.io/rezapr2

# Target architecture of the VPS — check with `uname -m` on the VPS:
#   x86_64  -> linux/amd64   (default; almost all providers)
#   aarch64 -> linux/arm64
PLATFORM=linux/amd64

# Optional: tag to publish. Leave as latest for normal deploys.
IMAGE_TAG=latest

# Social login client IDs (public values — safe here). Leave blank to disable.
GOOGLE_CLIENT_ID=
APPLE_CLIENT_ID=
